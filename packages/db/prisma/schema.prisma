// Reminder Management System — Prisma Schema v1.1
// Run `npm run generate` after changes.
// Run `npm run migrate` to apply to the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole      { user system_admin }
enum UserStatus      { active disabled deleted }
enum EventStatus     { active cancelled archived }
enum EventRole       { owner contributor reader }
enum SubscriberStatus { active unsubscribed }
enum ContactChannel  { email sms }
enum ContactStatus   { active inactive }
enum ReminderStatus  { scheduled processing recurring sent cancelled failed }
enum RecurrenceType  {
  never hourly daily weekdays weekends weekly
  fortnightly monthly every_3_months every_6_months yearly
}
enum DispatchStatus  { pending sent failed skipped }
enum ApiKeyStatus    { active revoked }
enum ApiKeyScope {
  users_read        @map("users:read")
  events_read       @map("events:read")
  events_write      @map("events:write")
  subscribers_read  @map("subscribers:read")
  subscribers_write @map("subscribers:write")
  reports_read      @map("reports:read")
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  updatedById String?  @map("updated_by_id") @db.Uuid
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy   User?    @relation(fields: [updatedById], references: [id])
  @@map("system_settings")
}

model User {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstname        String     @db.VarChar(100)
  lastname         String     @db.VarChar(100)
  email            String     @unique @db.VarChar(255)
  phone            String?    @db.VarChar(30)
  passwordHash     String     @map("password_hash")
  timezone         String     @default("UTC") @db.VarChar(60)
  systemRole       SystemRole @default(user) @map("system_role")
  status           UserStatus @default(active)
  emailVerified    Boolean    @default(false) @map("email_verified")
  emailVerifiedAt  DateTime?  @map("email_verified_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at")
  apiKeys          ApiKey[]
  ownedEvents      Event[]    @relation("EventOwner")
  createdEvents    Event[]    @relation("EventCreator")
  eventAccess      EventAccess[] @relation("UserAccess")
  grantedAccess    EventAccess[] @relation("AccessGrantedBy")
  subscriberLinks  Subscriber[]
  emailWrapper     EmailWrapperSetting?
  verificationTokens EmailVerificationToken[]
  settingUpdates   SystemSetting[]
  @@index([status])
  @@map("users")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("email_verification_tokens")
}

model ApiKey {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  keyHash    String       @unique @map("key_hash") @db.VarChar(128)
  keyPrefix  String       @map("key_prefix") @db.VarChar(8)
  name       String       @db.VarChar(100)
  status     ApiKeyStatus @default(active)
  lastUsedAt DateTime?    @map("last_used_at")
  expiresAt  DateTime?    @map("expires_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  revokedAt  DateTime?    @map("revoked_at")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes     ApiKeyScope_[]
  @@index([userId])
  @@map("api_keys")
}

model ApiKeyScope_ {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId  String      @map("api_key_id") @db.Uuid
  scope     ApiKeyScope
  createdAt DateTime    @default(now()) @map("created_at")
  apiKey    ApiKey      @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  @@unique([apiKeyId, scope])
  @@map("api_key_scopes")
}

model EmailWrapperSetting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String   @unique @map("owner_id") @db.Uuid
  wrapperHtml String   @map("wrapper_html")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  @@map("email_wrapper_settings")
}

model Event {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId       String      @map("owner_id") @db.Uuid
  createdById   String      @map("created_by_id") @db.Uuid
  subject       String      @db.VarChar(255)
  description   String?
  eventDatetime DateTime    @map("event_datetime")
  eventTimezone String      @default("UTC") @map("event_timezone") @db.VarChar(60)
  location      String?     @db.VarChar(500)
  status        EventStatus @default(active)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")
  owner         User        @relation("EventOwner", fields: [ownerId], references: [id])
  createdBy     User        @relation("EventCreator", fields: [createdById], references: [id])
  access        EventAccess[]
  subscribers   Subscriber[]
  reminders     Reminder[]
  @@index([ownerId])
  @@index([status, eventDatetime])
  @@map("events")
}

model EventAccess {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String    @map("event_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        EventRole
  grantedById String    @map("granted_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User      @relation("UserAccess", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User      @relation("AccessGrantedBy", fields: [grantedById], references: [id])
  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_access")
}

model Subscriber {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId    String           @map("event_id") @db.Uuid
  userId     String?          @map("user_id") @db.Uuid
  firstname  String           @db.VarChar(100)
  lastname   String           @db.VarChar(100)
  timezone   String?          @db.VarChar(60)
  status     SubscriberStatus @default(active)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @default(now()) @updatedAt @map("updated_at")
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  contacts   SubscriberContact[]
  dispatches ReminderDispatch[]
  @@index([eventId])
  @@index([eventId, status])
  @@map("subscribers")
}

model SubscriberContact {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriberId String         @map("subscriber_id") @db.Uuid
  channel      ContactChannel
  contactValue String         @map("contact_value") @db.VarChar(320)
  isPrimary    Boolean        @default(false) @map("is_primary")
  label        String?        @db.VarChar(100)
  status       ContactStatus  @default(active)
  createdAt    DateTime       @default(now()) @map("created_at")
  subscriber   Subscriber     @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  dispatches   ReminderDispatch[]
  @@index([subscriberId])
  @@index([subscriberId, channel, isPrimary])
  @@map("subscriber_contacts")
}

model Reminder {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String         @map("event_id") @db.Uuid
  remindAt         DateTime       @map("remind_at")
  subjectTemplate  String         @map("subject_template") @db.VarChar(500)
  bodyTemplate     String         @map("body_template")
  channels         ContactChannel[]
  recurrence       RecurrenceType @default(never)
  nextRemindAt     DateTime?      @map("next_remind_at")
  lastDispatchedAt DateTime?      @map("last_dispatched_at")
  occurrenceCount  Int            @default(0) @map("occurrence_count")
  status           ReminderStatus @default(scheduled)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at")
  event            Event          @relation(fields: [eventId], references: [id])
  dispatches       ReminderDispatch[]
  reports          ReminderReport[]
  @@index([eventId])
  @@index([status, remindAt])
  @@index([status, nextRemindAt])
  @@map("reminders")
}

model ReminderDispatch {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reminderId          String         @map("reminder_id") @db.Uuid
  subscriberId        String         @map("subscriber_id") @db.Uuid
  subscriberContactId String         @map("subscriber_contact_id") @db.Uuid
  channel             ContactChannel
  occurrenceNumber    Int            @default(1) @map("occurrence_number")
  renderedSubject     String?        @map("rendered_subject") @db.VarChar(500)
  renderedBody        String         @map("rendered_body")
  status              DispatchStatus @default(pending)
  attempts            Int            @default(0) @db.SmallInt
  lastAttemptedAt     DateTime?      @map("last_attempted_at")
  sentAt              DateTime?      @map("sent_at")
  failureReason       String?        @map("failure_reason")
  createdAt           DateTime       @default(now()) @map("created_at")
  reminder            Reminder       @relation(fields: [reminderId], references: [id])
  subscriber          Subscriber     @relation(fields: [subscriberId], references: [id])
  subscriberContact   SubscriberContact @relation(fields: [subscriberContactId], references: [id])
  @@index([reminderId, occurrenceNumber])
  @@index([subscriberId])
  @@index([status, attempts, lastAttemptedAt])
  @@map("reminder_dispatches")
}

model ReminderReport {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reminderId       String    @map("reminder_id") @db.Uuid
  occurrenceNumber Int       @default(1) @map("occurrence_number")
  totalDispatches  Int       @default(0) @map("total_dispatches")
  totalSent        Int       @default(0) @map("total_sent")
  totalFailed      Int       @default(0) @map("total_failed")
  totalSkipped     Int       @default(0) @map("total_skipped")
  failureDetails   Json?     @map("failure_details")
  reportSentToOwner Boolean  @default(false) @map("report_sent_to_owner")
  reportSentAt     DateTime? @map("report_sent_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  reminder         Reminder  @relation(fields: [reminderId], references: [id])
  @@unique([reminderId, occurrenceNumber])
  @@index([reminderId])
  @@map("reminder_reports")
}
