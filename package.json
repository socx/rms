{
  "name": "rms",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/db"
  ],
  "scripts": {
    "dev:api": "npm run dev   --workspace=apps/api",
    "dev:web": "npm run dev   --workspace=apps/web",
    "dev:worker": "bash -lc \"cd apps/worker && . .venv_worker/bin/activate && exec python main.py\"",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:worker\"",
    "certs:generate": "node infra/scripts/generate-dev-certs.js",
    "dev:secure": "node infra/scripts/dev-with-certs.js",
    "dev:ssl-port": "node infra/wait-for-ssl-port.js",
    "build:web": "npm run build --workspace=apps/web",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:apply:migration": "make apply-migration",
    "db:generate": "npm run generate --workspace=packages/db",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "selfsigned": "^2.1.1"
  }
}
