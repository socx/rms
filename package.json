{
  "name": "rms",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/db"
  ],
  "scripts": {
    "dev:api": "npm run dev   --workspace=apps/api",
    "dev:web": "npm run dev   --workspace=apps/web",
    "dev:worker": "bash -lc \"cd apps/worker && . .venv_worker/bin/activate && python main.py\"",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:worker\"",
    "build:web": "npm run build --workspace=apps/web",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:generate": "npm run generate --workspace=packages/db",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
